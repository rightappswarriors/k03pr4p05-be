// used in pos terminal to track items in a transaction, separate from inventory which tracks stock levels. this allows us to record the price and quantity of each item at the time of sale, even if the inventory levels change later. it also allows us to track the unit of measurement used for each item in the transaction, which may be different from the base unit used in inventory.
model CartItem {
  transactionId     Int
  itemId            Int
  quantity          Float
  priceAtSale       Float              @default(0)
  unitId            Int?
  unitName          String?
  discountAmount    Float?             @default(0)
  discountQuantity  Float?             @default(0) // ← NEW: quantity that gets the discount
  discountRate      Float?             @default(0) // ← NEW: discount percentage (0.0 - 1.0)
  discountType      DiscountType       @default(NONE)
  originalPrice     Float              @default(0)
  vatExclusivePrice Float              @default(0)
  finalPrice        Float              @default(0)
  item              Item               @relation(fields: [itemId], references: [id])
  transaction       Transaction        @relation(fields: [transactionId], references: [id])
  unit              InventoryItemUnit? @relation(fields: [unitId], references: [id])

  @@id([transactionId, itemId])
}

