generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   Int              @id @default(autoincrement())
  fullname             String
  username             String           @unique
  email                String           @unique
  role                 Role             @default(CASHIER)
  password             String
  createdAt            DateTime         @default(now())
  profilePhoto         String?
  managerId            Int?
  enabledPaymentMethod Boolean          @default(false)
  contactNumber        String?
  branchesOwned        Branch[]         @relation("UserBranches")
  outletOwned          Outlet[]         @relation("UserOutlets")
  outletStaff          OutletStaff[]
  paymongoAPIKeys      PaymongoAPIKeys?
  Transaction          Transaction[]
  manager              User?            @relation("ManagerToStaff", fields: [managerId], references: [id])
  staff                User[]           @relation("ManagerToStaff")
}

model PaymongoAPIKeys {
  id         Int      @id @default(autoincrement())
  public_key String
  secret_key String
  ownerId    Int      @unique
  owner      User     @relation(fields: [ownerId], references: [id])
  outlets    Outlet[] @relation("OutletApiKeys")
}

model Branch {
  id         Int            @id @default(autoincrement())
  name       String
  address    String
  phone      String?
  isActive   Boolean        @default(true)
  createdAt  DateTime       @default(now())
  location   PlaceLocation?
  ownerId    Int
  owner      User           @relation("UserBranches", fields: [ownerId], references: [id])
  outlets    Outlet[]
  locationId Int?
}

model PlaceLocation {
  id        Int    @id @default(autoincrement())
  address   String
  latitude  Float
  longitude Float
  branchId  Int    @unique
  branch    Branch @relation(fields: [branchId], references: [id])
}

model Outlet {
  id                    Int              @id @default(autoincrement())
  name                  String
  address               String
  phone                 String?
  code                  String           @unique
  nextTransactionNumber Int?             @default(1)
  status                OutletStatus     @default(open)
  governmentTax         Float?
  serviceCharge         Float?
  outletType            OutletType
  isActive              Boolean          @default(true)
  wifiSSID              String?
  createdAt             DateTime         @default(now())
  branchId              Int
  ownerId               Int
  apiKeyId              Int?
  apiKey                PaymongoAPIKeys? @relation("OutletApiKeys", fields: [apiKeyId], references: [id])
  hasKey                Boolean          @default(false)
  inventory             Inventory?
  branch                Branch           @relation(fields: [branchId], references: [id])
  owner                 User             @relation("UserOutlets", fields: [ownerId], references: [id])
  staff                 OutletStaff[]
  Transaction           Transaction[]
}

enum OutletStatus {
  open
  closed
  maintainance
}

model OutletStaff {
  id        Int     @id @default(autoincrement())
  outletId  Int
  userId    Int
  role      Role
  isPresent Boolean @default(false)
  outlet    Outlet  @relation(fields: [outletId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@unique([outletId, userId])
}

model UnauthorizedAttempt {
  id                Int      @id @default(autoincrement())
  outletId          Int
  attemptedDeviceId String
  timestamp         DateTime @default(now())
}

model Inventory {
  id       Int              @id @default(autoincrement())
  name     String?
  outletId Int              @unique
  outlet   Outlet           @relation(fields: [outletId], references: [id], onDelete: Cascade)
  items    InventoryItems[]
}

model Location {
  id    Int             @id @default(autoincrement())
  aisle String?
  rack  String?
  shelf String?
  item  InventoryItems?
}

model InventoryItems {
  id          Int       @id @default(autoincrement())
  inventoryId Int
  itemId      Int
  price       Float
  quantity    Int       @default(0)
  locationId  Int?      @unique
  inventory   Inventory @relation(fields: [inventoryId], references: [id])
  item        Item      @relation(fields: [itemId], references: [id])
  location    Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([inventoryId, itemId])
}

model Category {
  id           Int     @id @default(autoincrement())
  name         String  @unique
  cost_of_sale String?
  description  String?
  groupType    String?
  sales        String?
  stocks       String?
  items        Item[]
}

model Color {
  id      Int     @id @default(autoincrement())
  name    String  @unique
  hexCode String?
  items   Item[]  @relation("ColorToItem")
}

model Item {
  id             Int              @id @default(autoincrement())
  name           String           @unique
  image          String?
  description    String?
  barcode        String
  brand          String?
  categoryId     Int?
  brandId        Int?
  ServiceCharge  Boolean          @default(false)
  assembly       Boolean          @default(false)
  itemCode       String?
  skuNumber      String?
  vatExempt      Boolean          @default(false)
  cartItems      CartItem[]
  InventoryItems InventoryItems[]
  brandDetails   Brand?           @relation(fields: [brandId], references: [id])
  category       Category?        @relation(fields: [categoryId], references: [id])
  color          Color[]          @relation("ColorToItem")
  purchaseUnit   ItemUnit[]       @relation("ItemToItemUnit")
}

model StockLocation {
  id      Int    @id @default(autoincrement())
  name    String
  address String
}

model Brand {
  id            Int     @id @default(autoincrement())
  email         String?
  webUrl        String?
  contactNumber String?
  name          String  @unique
  Item          Item[]
}

model ItemUnit {
  id          Int     @id @default(autoincrement())
  unitName    String  @unique
  description String?
  Item        Item[]  @relation("ItemToItemUnit")
}

model CartItem {
  transactionId Int
  itemId        Int
  quantity      Int
  item          Item        @relation(fields: [itemId], references: [id])
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  @@id([transactionId, itemId])
}

model Transaction {
  id                Int              @id @default(autoincrement())
  outletId          Int
  cashierId         Int
  total             Float
  vatAmount         Float
  subtotal          Float
  cashReceived      Float?
  change            Float?
  paymentMethod     PaymentMethod
  status            Status
  createdAt         DateTime
  syncedAt          DateTime         @default(now())
  customerDetailsId Int?
  items             CartItem[]
  customerDetails   CustomerDetails?
  cashier           User             @relation(fields: [cashierId], references: [id])
  outlet            Outlet           @relation(fields: [outletId], references: [id])
}

model CustomerDetails {
  id              Int         @id @default(autoincrement())
  fullname        String?
  username        String?
  email           String?
  phoneNumber     String?
  paymentType     PaymentType
  paymentMethodId String?
  paymentIntentId String?
  client_key      String?
  status          String?
  transactionId   Int         @unique
  transaction     Transaction @relation(fields: [transactionId], references: [id])
}

model Supplier {
  id             Int             @id @default(autoincrement())
  name           String
  address        String?
  zipCode        String?
  contactNumber  String
  contactName    String
  faxNumber      String?
  tinNumber      String?
  modesOfPayment ModeOfPayment[]
}

model ModeOfPayment {
  id          Int          @id @default(autoincrement())
  name        String
  supplierId  Int
  accountLink AccountLink?
  supplier    Supplier     @relation(fields: [supplierId], references: [id])
}

enum Role {
  ADMIN
  MANAGER
  STAFF
  CASHIER
  OWNER
}

enum OutletType {
  retail
  wholesale
  service
}

enum PaymentMethod {
  CARD
  CASH
  E_WALLET
}

enum Status {
  PENDING
  PAID
  SYNCED
  FAILED
  CANCELED
}

enum PaymentType {
  gcash
  paymaya
  card
  qrph
}

enum AccountLink {
  CASH_ON_HAND                               @map("Cash on Hand")
  CASH_IN_BANK_BDO                           @map("Cash in Bank - BDO")
  CASH_IN_BANK_CHINABANK                     @map("Cash in Bank - Chinabank")
  CASH_IN_BANK_SECURITY_BANK                 @map("Cash in Bank - Security Bank")
  ACCOUNTS_RECEIVABLE_TRADE                  @map("Accounts Receivable - Trade")
  ACCOUNTS_RECEIVABLE_NON_TRADE              @map("Accounts Receivable - Non-Trade")
  ADVANCES_TO_AFFILIATES                     @map("Advances to Affiliates")
  ADVANCES_TO_EMPLOYEES                      @map("Advances to Employees")
  ADVANCES_TO_OFFICERS_STOCKHOLDERS          @map("Advances to Officers/Stockholders")
  ADVANCES_TO_OUTSIDE_PERSONNEL              @map("Advances to Outside Personnel")
  INVENTORY_ALL_STOCKS                       @map("Inventory - All Stocks")
  PREPAID_INSURANCE                          @map("Prepaid Insurance")
  PETTY_CASH_FUND                            @map("Petty Cash Fund")
  OFFICE_EQUIPMENT                           @map("Office Equipment")
  OFFICE_FURNITURES_FIXTURES                 @map("Office Furnitures & Fixtures")
  OFFICE_SUPPLIES                            @map("Office Supplies")
  UNUSED_OFFICE_SUPPLIES                     @map("Unused Office Supplies")
  DELIVERY_VEHICLE                           @map("Delivery Vehicle")
  SERVICE_VEHICLE                            @map("Service Vehicle")
  LAND                                       @map("Land")
  LEASEHOLD_IMPROVEMENTS                     @map("Leasehold Improvements")
  SUBSCRIPTION_RECEIVABLE                    @map("Subscription Receivable")
  VAT_INPUT                                  @map("VAT Input")
  ACCUMULATED_DEP_DELIVERY_VEHICLE           @map("Accumulated Depreciation - Delivery Vehicle")
  ACCUMULATED_DEP_LEASEHOLD_IMPROVEMENTS     @map("Accumulated Depreciation - Leasehold Improvements")
  ACCUMULATED_DEP_OFFICE_EQUIPMENT           @map("Accumulated Depreciation - Office Equipment")
  ACCUMULATED_DEP_OFFICE_FURNITURES_FIXTURES @map("Accumulated Depreciation - Office Furnitures & Fixtures")
  ACCUMULATED_DEP_SERVICE_VEHICLE            @map("Accumulated Depreciation - Service Vehicle")
  ACCOUNTS_PAYABLE_TRADE                     @map("Accounts Payable - Trade")
  ACCOUNTS_PAYABLE_NON_TRADE                 @map("Accounts Payable - Non-Trade")
  ACCRUED_EXPENSES                           @map("Accrued Expenses")
  INCOME_TAX_PAYABLE                         @map("Income Tax Payable")
  VAT_PAYABLE                                @map("VAT Payable")
  WITHHOLDING_TAX_PAYABLE                    @map("Withholding Tax Payable")
  SSS_PHILHEALTH_PAGIBIG_CONTRIBUTIONS       @map("SSS, PhilHealth & Pag-IBIG Contributions")
  ORDINARY_SHARES                            @map("Ordinary Shares")
  SUBSCRIBED_ORDINARY_SHARES                 @map("Subscribed Ordinary Shares")
  RETAINED_EARNINGS                          @map("Retained Earnings")
  INTEREST_INCOME                            @map("Interest Income")
  MISCELLANEOUS_INCOME                       @map("Miscellaneous Income")
  OUTPUT_VAT                                 @map("Output VAT")
  COST_OF_SALES_ALL_STOCKS                   @map("Cost of Sales - All Stocks")
  DEPRECIATION                               @map("Depreciation")
  ELECTRICITY                                @map("Electricity")
  COMMUNICATION                              @map("Communication")
  EMPLOYEE_BENEFITS                          @map("Employee Benefits")
  FUEL_OIL                                   @map("Fuel & Oil")
  INSURANCE                                  @map("Insurance")
  PROFESSIONAL_FEE                           @map("Professional Fee")
  RENT                                       @map("Rent")
  REPAIRS_MAINTENANCE                        @map("Repairs & Maintenance")
  REPRESENTATION                             @map("Representation")
  SALARIES_WAGES                             @map("Salaries & Wages")
  TAXES_LICENSES                             @map("Taxes & Licenses")
  TRANSPORTATION_TRAVEL                      @map("Transportation & Travel")
  WATER                                      @map("Water")
  INCOME_TAX                                 @map("Income Tax")
}
