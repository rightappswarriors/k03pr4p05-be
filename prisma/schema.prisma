generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id               Int               @id @default(autoincrement())
  name             String
  createdAt        DateTime          @default(now())
  accountTitles    AccountTitle[]
  attendances      Attendance[]
  branches         Branch[]
  brands           Brand[]
  centers          Center[]
  departments      Department[]
  employees        Employee[]
  gisRows          GISRow[]
  inventoryItems   InventoryItem[]
  items            Item[]
  outlets          Outlet[]
  positions        Position[]
  promoTypes       PromoType[]
  salesOrders      SalesOrder[]
  shifts           Shift[]
  subCenters       SubCenter[]
  subscription     Subscription?
  summaryRows      SummaryRow[]
  supplierOrders   SupplierOrder[]
  stockBatches     StockBatch[]
  restockSchedules RestockSchedule[]
  users            User[]
  vatTypes         VatType[]
  restockCycles    RestockCycle[]
  itemGroups       ItemGroup[]
  orgCategories    OrgItemCategory[]
  contacts         Contact[]
  notifications    Notification[]
}

model Subscription {
  id        Int              @id @default(autoincrement())
  orgId     Int              @unique
  plan      SubscriptionPlan @default(BASIC)
  expiresAt DateTime?
  features  Json?
  createdAt DateTime         @default(now())
  org       Organization     @relation(fields: [orgId], references: [id])
}

model User {
  id                   Int                      @id @default(autoincrement())
  fullname             String
  username             String                   @unique
  email                String                   @unique
  role                 Role                     @default(CASHIER)
  password             String
  createdAt            DateTime                 @default(now())
  profilePhoto         String?
  managerId            Int?
  enabledPaymentMethod Boolean                  @default(false)
  contactNumber        String?
  orgId                Int?
  isVerified           Boolean                  @default(false)
  verificationCode     String?
  attendances          Attendance[]
  branchesOwned        Branch[]                 @relation("UserBranches")
  employees            Employee[]
  gisRows              GISRow[]
  inventoryItems       InventoryItem[]
  outletOwned          Outlet[]                 @relation("UserOutlets")
  outletPromo          OutletPromo[]            @relation("UserOutletPromos")
  outletStaff          OutletStaff[]
  paymongoAPIKeys      PaymongoAPIKeys?
  promoType            PromoType[]              @relation("UserPromoTypes")
  salesOrders          SalesOrder[]
  summaryRows          SummaryRow[]
  Transaction          Transaction[]
  manager              User?                    @relation("ManagerToStaff", fields: [managerId], references: [id])
  staff                User[]                   @relation("ManagerToStaff")
  org                  Organization?            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userShifts           UserShift[]
  departmentId         Int?
  department           Department?              @relation(fields: [departmentId], references: [id])
  positionId           String?
  isOwner              Boolean                  @default(false)
  position             Position?                @relation(fields: [positionId], references: [id])
  auditLogs            AuditLog[]
  permissionOverrides  UserPermissionOverride[]

  @@unique([orgId, username])
  @@unique([orgId, email])
}

model PaymongoAPIKeys {
  id         Int      @id @default(autoincrement())
  public_key String
  secret_key String
  ownerId    Int      @unique
  outlets    Outlet[] @relation("OutletApiKeys")
  owner      User     @relation(fields: [ownerId], references: [id])
}

model Branch {
  id               Int               @id @default(autoincrement())
  name             String
  address          String
  phone            String?
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  orgId            Int
  ownerId          Int
  locationId       Int?
  org              Organization      @relation(fields: [orgId], references: [id])
  owner            User              @relation("UserBranches", fields: [ownerId], references: [id], onDelete: Cascade)
  outlets          Outlet[]
  location         PlaceLocation?
  restockCycles    RestockCycle[]
  restockSchedules RestockSchedule[]
  contacts         Contact[]

  @@unique([orgId, name])
}

model Contact {
  id         Int      @id @default(autoincrement())
  orgId      Int
  branchId   Int? // null = global (visible to all branches), set = branch-specific
  label      String // Required display label / nickname (e.g. "Main Supplier - Cebu")
  name       String // Full name
  email      String
  phone      String?
  position   String?
  department String?
  notes      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  org    Organization @relation(fields: [orgId], references: [id])
  branch Branch?      @relation(fields: [branchId], references: [id])

  @@index([orgId])
  @@index([orgId, branchId])
}

model PlaceLocation {
  id        Int    @id @default(autoincrement())
  address   String
  latitude  Float
  longitude Float
  branchId  Int    @unique
  branch    Branch @relation(fields: [branchId], references: [id])
}

model Outlet {
  id                    Int                     @id @default(autoincrement())
  name                  String
  address               String
  phone                 String?
  code                  String                  @unique
  nextTransactionNumber Int?                    @default(1)
  governmentTax         Float?
  serviceCharge         Float?
  outletType            OutletType
  isActive              Boolean                 @default(true)
  wifiSSID              String?
  createdAt             DateTime                @default(now())
  orgId                 Int
  branchId              Int?
  ownerId               Int
  apiKeyId              Int?
  hasKey                Boolean                 @default(false)
  status                OutletStatus            @default(open)
  latitude              Float?
  longitude             Float?
  bannerImage           String?
  inventory             Inventory?
  kompraCOrders         KompraCOrder[]
  apiKey                PaymongoAPIKeys?        @relation("OutletApiKeys", fields: [apiKeyId], references: [id])
  branch                Branch?                 @relation(fields: [branchId], references: [id])
  org                   Organization            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner                 User                    @relation("UserOutlets", fields: [ownerId], references: [id], onDelete: Cascade)
  deliveryConfig        OutletDeliveryConfig?
  itemSearchIndex       OutletItemSearchIndex[]
  outletPromos          OutletPromo[]
  staff                 OutletStaff[]
  Transaction           Transaction[]
  restockCycles         RestockCycle[]
  restockSchedules      RestockSchedule[]
  tin                   String?
  ptu                   String?
  bir                   String?
  isVatRegistered       Boolean                 @default(false)
  vatZeroSale           Float?                  @default(0)

  vatTypeId     Int?
  vatType       VatType?       @relation(fields: [vatTypeId], references: [id])
  notifications Notification[]

  @@unique([orgId, code])
}

model PromoType {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  description  String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  orgId        Int
  userId       Int?
  outletPromos OutletPromo[]
  org          Organization  @relation(fields: [orgId], references: [id])
  user         User?         @relation("UserPromoTypes", fields: [userId], references: [id])

  @@unique([orgId, name])
}

model OutletPromo {
  id          Int       @id @default(autoincrement())
  outletId    Int
  promoTypeId Int
  discount    Float
  vatable     Boolean   @default(false)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  userId      Int
  outlet      Outlet    @relation(fields: [outletId], references: [id], onDelete: Cascade)
  promoType   PromoType @relation(fields: [promoTypeId], references: [id], onDelete: Cascade)
  user        User      @relation("UserOutletPromos", fields: [userId], references: [id])

  @@unique([outletId, promoTypeId])
}

model OutletStaff {
  id        Int       @id @default(autoincrement())
  outletId  Int
  userId    Int
  role      Role
  isPresent Boolean   @default(false)
  logInTime DateTime?
  outlet    Outlet    @relation(fields: [outletId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([outletId, userId])
}

model UnauthorizedAttempt {
  id                Int      @id @default(autoincrement())
  outletId          Int
  attemptedDeviceId String
  timestamp         DateTime @default(now())
}

model Inventory {
  id       Int              @id @default(autoincrement())
  name     String?
  outletId Int              @unique
  outlet   Outlet           @relation(fields: [outletId], references: [id], onDelete: Cascade)
  items    InventoryItems[]
}

model Location {
  id    Int             @id @default(autoincrement())
  aisle String?
  rack  String?
  shelf String?
  item  InventoryItems?
}

model StockMovement {
  id              Int               @id @default(autoincrement())
  itemId          Int
  inventoryItemId Int?
  outletId        Int?
  type            StockMovementType
  quantity        Float // always in base units
  quantityBefore  Float
  quantityAfter   Float
  referenceId     String? // transactionId, orderId
  referenceType   String? // "TRANSACTION", "ASSIGN", "RESTOCK"
  reason          String?
  createdAt       DateTime          @default(now())
  createdBy       Int
  item            Item              @relation(fields: [itemId], references: [id])
}

enum StockMovementType {
  ASSIGN_TO_OUTLET
  SALE
  RESTOCK_TO_OUTLET
  PURCHASE_RECEIVED
  CUSTOMER_RETURN
  WRITE_OFF
  ADJUSTMENT
}

model InventoryItems {
  id          Int                    @id @default(autoincrement())
  inventoryId Int
  itemId      Int
  price       Float
  baseUnit    String                 @default("piece")
  // ↑ "kg", "piece", "liter" — the unit quantity is stored in
  quantity    Int                    @default(0)
  locationId  Int?                   @unique
  units       InventoryItemUnit[]
  inventory   Inventory              @relation(fields: [inventoryId], references: [id])
  item        Item                   @relation(fields: [itemId], references: [id])
  location    Location?              @relation(fields: [locationId], references: [id], onDelete: Cascade)
  orderItems  KompraCOrderItem[]
  searchIndex OutletItemSearchIndex?
  categoryId  Int?
  category    ItemCategory?          @relation(fields: [categoryId], references: [id])

  @@unique([inventoryId, itemId])
}

// Global - super admin managed (no orgId)
model ItemCategory {
  id             Int               @id @default(autoincrement())
  name           String            @unique
  description    String?
  icon           String?
  groupType      String?
  sales          String?
  stocks         String?
  items          Item[]            @relation("GlobalItemCategory")
  createdAt      DateTime          @default(now())
  orgCategories  OrgItemCategory[] // orgs customize from this
  inventoryItems InventoryItems[]
}

// Org's customized version of a global category
model OrgItemCategory {
  id             Int               @id @default(autoincrement())
  orgId          Int
  categoryId     Int? // ✅ make optional — org doesn't need a global template
  name           String // required now — org must provide their own name
  description    String?
  icon           String?
  cost_of_sale   String?
  groupType      String?
  sales          String?
  stocks         String?
  groupId        Int?
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  org            Organization      @relation(fields: [orgId], references: [id])
  globalCategory ItemCategory?     @relation(fields: [categoryId], references: [id]) // ✅ optional
  group          ItemGroup?        @relation(fields: [groupId], references: [id])
  items          Item[]
  itemCategories ItemCategoryMap[]

  @@unique([orgId, name]) // ✅ unique per org by name, not by categoryId
}

// Org-specific groups
model ItemGroup {
  id          Int               @id @default(autoincrement())
  name        String
  description String?
  icon        String?
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  orgId       Int
  org         Organization      @relation(fields: [orgId], references: [id])
  categories  OrgItemCategory[]

  @@unique([orgId, name])
}

// Update ItemCategoryMap to point to OrgItemCategory
model ItemCategoryMap {
  itemId     Int
  categoryId Int
  category   OrgItemCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  item       Item            @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([itemId, categoryId])
}

model Item {
  id                   Int                     @id @default(autoincrement())
  name                 String                  @unique
  image                String?
  description          String?
  barcode              String
  brand                String?
  orgId                Int
  brandId              Int?
  ServiceCharge        Boolean                 @default(false)
  assembly             Boolean                 @default(false)
  itemCode             String?
  skuNumber            String?
  vatExempt            Boolean?
  stockLabel           String?
  stockDescription     String?
  stock                Float                   @default(0)
  sellingPrice         Float                   @default(0)
  minQuantity          Float                   @default(0)
  opExPct              Float                   @default(0.1)
  priceB               Float?
  priceC               Float?
  totalCost            Float                   @default(0)
  expiryStartDate      DateTime?
  expiryEndDate        DateTime?
  exactExpiryDate      DateTime?
  cartItems            CartItem[]
  costLines            CostLines[]
  InventoryItems       InventoryItems[]
  brandDetails         Brand?                  @relation(fields: [brandId], references: [id])
  categoryId           Int?
  category             ItemCategory?           @relation("GlobalItemCategory", fields: [categoryId], references: [id]) // ✅ matches
  org                  Organization            @relation(fields: [orgId], references: [id])
  categories           ItemCategoryMap[]
  orderItems           KompraCOrderItem[]
  media                Media[]
  searchIndex          OutletItemSearchIndex[]
  color                Color[]                 @relation("ColorToItem")
  purchaseUnit         ItemUnit[]              @relation("ItemToItemUnit")
  supplierOrderItems   SupplierOrderItem[]
  stockBatches         StockBatch[]
  restockScheduleItems RestockScheduleItem[]
  restockCycleItems    RestockCycleItem[]
  orgCategoryId        Int? // → OrgItemCategory ✅ new
  orgCategory          OrgItemCategory?        @relation(fields: [orgCategoryId], references: [id])
  vatTypeId            Int?
  vatType              VatType?                @relation(fields: [vatTypeId], references: [id])
  stockMovements       StockMovement[]
  notifications        Notification[]
  summaryRows          SummaryRow[]

  @@unique([orgId, name])
}

model Color {
  id      Int     @id @default(autoincrement())
  name    String  @unique
  hexCode String?
  items   Item[]  @relation("ColorToItem")
}

model CostLines {
  id     Int    @id @default(autoincrement())
  itemId Int
  label  String
  amount Float
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}

enum SupplierOrderStatus {
  pending // email sent, waiting for supplier
  acknowledged // supplier opened portal
  sent // supplier confirmed dispatch
  delivered // user confirmed receipt
  cancelled
}

model SupplierOrder {
  id              Int                 @id @default(autoincrement())
  orgId           Int
  scheduleId      Int?
  supplierEmail   String
  supplierToken   String              @unique // JWT or UUID stored here
  tokenExpiresAt  DateTime
  status          SupplierOrderStatus @default(pending)
  supplierMessage String? // supplier's reply message
  userMessage     String? // message from user to supplier
  expectedArrival DateTime
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  org      Organization        @relation(fields: [orgId], references: [id])
  schedule RestockSchedule?    @relation(fields: [scheduleId], references: [id])
  items    SupplierOrderItem[]
  cycleId  Int?
  cycle    RestockCycle?       @relation(fields: [cycleId], references: [id])

  @@index([orgId, status])
  @@index([supplierToken])
}

model SupplierOrderItem {
  id              Int       @id @default(autoincrement())
  orderId         Int
  itemId          Int
  requestedQty    Float // what we asked for
  deliveredQty    Float? // what supplier says they'll send
  confirmedQty    Float? // what user confirms on arrival
  expiryStartDate DateTime?
  expiryEndDate   DateTime?
  exactExpiryDate DateTime?

  order SupplierOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  item  Item          @relation(fields: [itemId], references: [id])

  @@index([orderId])
}

model RestockCycle {
  id             Int       @id @default(autoincrement())
  scheduleId     Int
  orgId          Int
  branchId       Int?
  outletId       Int?
  address        String?
  latitude       Float?
  longitude      Float?
  scheduledAt    DateTime // exact UTC moment this cycle fires
  emailRecipient String // may override schedule.emailRecipient
  emailSubject   String?
  emailBody      String?
  isActive       Boolean   @default(true)
  firedAt        DateTime? // set when BullMQ actually processed it
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  schedule       RestockSchedule    @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  org            Organization       @relation(fields: [orgId], references: [id])
  branch         Branch?            @relation(fields: [branchId], references: [id])
  outlet         Outlet?            @relation(fields: [outletId], references: [id])
  cycleItems     RestockCycleItem[]
  supplierOrders SupplierOrder[]

  @@index([scheduleId, scheduledAt])
  @@index([orgId, scheduledAt])
}

model RestockCycleItem {
  id       Int   @id @default(autoincrement())
  cycleId  Int
  itemId   Int
  quantity Float

  cycle RestockCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  item  Item         @relation(fields: [itemId], references: [id])

  @@unique([cycleId, itemId])
}

// Tracks each received batch — enables FEFO (first expired, first out)
model StockBatch {
  id              Int       @id @default(autoincrement())
  itemId          Int
  orgId           Int
  orderId         Int?
  quantity        Float
  remainingQty    Float // decremented as stock is consumed
  expiryStartDate DateTime?
  expiryEndDate   DateTime?
  exactExpiryDate DateTime?
  receivedAt      DateTime  @default(now())

  item Item         @relation(fields: [itemId], references: [id])
  org  Organization @relation(fields: [orgId], references: [id])

  @@index([itemId, expiryStartDate])
  @@index([itemId, exactExpiryDate])
}

// Remove: itemId Int
// Add:
model RestockSchedule {
  id              Int                   @id @default(autoincrement())
  orgId           Int
  branchId        Int?
  outletId        Int?
  address         String?
  latitude        Float?
  longitude       Float?
  recurrence      RecurrenceType
  startDate       DateTime
  endDate         DateTime?
  timeOfDay       String
  dayOfWeek       Int?
  dayOfMonth      Int?
  lastTriggeredAt DateTime?
  emailRecipient  String
  emailFrom       String?
  emailSubject    String?
  emailBody       String?
  customTimes     Json?
  isActive        Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  cycles          RestockCycle[]
  org             Organization          @relation(fields: [orgId], references: [id])
  branch          Branch?               @relation(fields: [branchId], references: [id])
  outlet          Outlet?               @relation(fields: [outletId], references: [id])
  scheduleItems   RestockScheduleItem[]
  supplierOrders  SupplierOrder[]
}

model RestockScheduleItem {
  id         Int             @id @default(autoincrement())
  scheduleId Int
  itemId     Int
  quantity   Float // quantity to request from supplier
  // Per-item timing overrides (nullable to fall back to schedule values)
  timeOfDay  String? // "HH:MM" format, if null uses schedule's timeOfDay
  dayOfWeek  Int? // 0-6 (Sunday-Saturday), if null uses schedule's dayOfWeek
  dayOfMonth Int? // 1-31, if null uses schedule's dayOfMonth
  schedule   RestockSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  item       Item            @relation(fields: [itemId], references: [id])

  @@unique([scheduleId, itemId])
}

enum RecurrenceType {
  once
  daily
  weekly
  monthly
  custom
}

// .... other models ....
model Media {
  id        Int        @id @default(autoincrement())
  url       String
  type      MediaType?
  itemId    Int?
  sortOrder Int        @default(0)
  item      Item?      @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, sortOrder])
}

model StockLocation {
  id      Int    @id @default(autoincrement())
  name    String
  address String
}

model Brand {
  id            Int          @id @default(autoincrement())
  email         String?
  webUrl        String?
  contactNumber String?
  name          String       @unique
  orgId         Int
  org           Organization @relation(fields: [orgId], references: [id])
  Item          Item[]

  @@unique([orgId, name])
}

model ItemUnit {
  id          Int     @id @default(autoincrement())
  unitName    String  @unique
  description String?
  Item        Item[]  @relation("ItemToItemUnit")
}

model CartItem {
  transactionId Int
  itemId        Int
  quantity      Float // Int → Float
  priceAtSale   Float              @default(0) // ← add
  unitId        Int? // ← add
  unitName      String? // ← add
  item          Item               @relation(fields: [itemId], references: [id])
  transaction   Transaction        @relation(fields: [transactionId], references: [id])
  unit          InventoryItemUnit? @relation(fields: [unitId], references: [id])

  @@id([transactionId, itemId])
}

model Notification {
  id        Int              @id @default(autoincrement())
  orgId     Int
  outletId  Int?
  itemId    Int?
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  org       Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  outlet    Outlet?          @relation(fields: [outletId], references: [id])
  item      Item?            @relation(fields: [itemId], references: [id])
}

enum NotificationType {
  OUTLET_LOW_STOCK
  ORG_CRITICAL_STOCK
  NEW_TRANSACTION
}

model Transaction {
  id                Int              @id @default(autoincrement())
  outletId          Int
  cashierId         Int
  total             Float
  vatAmount         Float
  subtotal          Float
  cashReceived      Float?
  change            Float?
  paymentMethod     PaymentMethod
  status            Status
  createdAt         DateTime
  syncedAt          DateTime         @default(now())
  customerDetailsId Int?
   // SC / PWD Benefit (government-mandated, separate from promos)
  isVatExempt       Boolean       @default(false)
  vatExemptType     VatExemptType?
  vatExemptRefNo    String?       // SC/PWD ID — BIR required on receipt
  vatExemptAmount   Float?        // total VAT stripped
  scPwdDiscountAmt  Float?        // 20% computed peso amount — for receipt
  items             CartItem[]
  customerDetails   CustomerDetails?
  cashier           User             @relation(fields: [cashierId], references: [id])
  outlet            Outlet           @relation(fields: [outletId], references: [id])
}

enum VatExemptType {
  SENIOR_CITIZEN
  PWD
  DIPLOMAT
  GOVERNMENT
}
model CustomerDetails {
  id              Int         @id @default(autoincrement())
  fullname        String?
  username        String?
  email           String?
  phoneNumber     String?
  paymentType     PaymentType
  paymentMethodId String?
  paymentIntentId String?
  client_key      String?
  status          String?
  transactionId   Int         @unique
  transaction     Transaction @relation(fields: [transactionId], references: [id])
}

model KompraCOrder {
  id                  Int                       @id @default(autoincrement())
  transactionNumber   String                    @unique
  customerId          Int
  outletId            Int
  deliveryAddressId   Int
  subtotal            Float
  total               Float
  status              OrderStatus               @default(pending)
  scheduledDeliveryAt DateTime?
  estimatedDeliveryAt DateTime?
  deliveredAt         DateTime?
  paymentMethod       KompraCPaymentMethod
  paymentStatus       String                    @default("unpaid")
  paymentReference    String?
  riderName           String?
  riderPhone          String?
  customerNote        String?
  outletNote          String?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  tracking            KompraCDeliveryTracking[]
  customer            KompraCustomer            @relation(fields: [customerId], references: [id])
  deliveryAddress     DeliveryAddress           @relation(fields: [deliveryAddressId], references: [id])
  outlet              Outlet                    @relation(fields: [outletId], references: [id])
  fees                KompraCOrderFee[]
  items               KompraCOrderItem[]
}

model KompraCustomer {
  id           Int                   @id @default(autoincrement())
  fullname     String
  email        String                @unique
  passwordHash String
  profilePhoto String?
  isVerified   Boolean               @default(false)
  isActive     Boolean               @default(true)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  phone        String?               @unique
  deviceTokens CustomerDeviceToken[]
  addresses    DeliveryAddress[]
  orders       KompraCOrder[]
}

model CustomerDeviceToken {
  id         Int            @id @default(autoincrement())
  customerId Int
  token      String         @unique
  platform   String
  createdAt  DateTime       @default(now())
  customer   KompraCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model DeliveryAddress {
  id         Int            @id @default(autoincrement())
  customerId Int
  label      String
  address    String
  latitude   Float
  longitude  Float
  isDefault  Boolean        @default(false)
  createdAt  DateTime       @default(now())
  customer   KompraCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orders     KompraCOrder[]
}

model KompraCOrderItem {
  id              Int                @id @default(autoincrement())
  orderId         Int
