  cashier           User?            @relation(fields: [cashierId], references: [id])
  discountType      DiscountType     @default(NONE)
  discountRate      Float            @default(0)
  discountAmount    Float            @default(0)
  totalPax          Int?
  scPwdPax          Int?
  outletPromoId     Int?
  promoDiscountAmt  Float?
