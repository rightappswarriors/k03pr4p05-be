  @@unique([userId, shiftId])
  @@index([userId])
  @@index([shiftId])
}

model Attendance {
  id              Int              @id @default(autoincrement())
  userId          Int
  shiftId         Int
  shiftDate       DateTime
  // Time In
  timeIn          DateTime?
  photoIn         String? // URL from your file service
  noteIn          String? // what they plan to do today
  // Break Start
  breakStart      DateTime?
  photoBreakStart String?
  noteBreakStart  String? // note when going on break
  // Break End
  breakEnd        DateTime?
  photoBreakEnd   String? // photo required on return
  noteBreakEnd    String? // note on return from break
  // Time Out
  timeOut         DateTime?
  photoOut        String?
  noteOut         String? // end of day note
  // Status & relations
  status          AttendanceStatus @default(PRESENT)
  orgId           Int
  org             Organization     @relation(fields: [orgId], references: [id])
  shift           Shift            @relation(fields: [shiftId], references: [id])
  user            User             @relation(fields: [userId], references: [id])

  @@unique([userId, shiftDate]) // one record per user per day — CRITICAL
  @@index([userId, shiftDate])
  @@index([shiftId, shiftDate])
  @@index([orgId, shiftDate]) // added orgId+date for owner queries
}

