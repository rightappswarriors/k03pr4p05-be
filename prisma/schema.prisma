model UnauthorizedAttempt {
  id                Int      @id @default(autoincrement())
  outletId          Int
  attemptedDeviceId String
  timestamp         DateTime @default(now())
}

model Inventory {
  id       Int              @id @default(autoincrement())
  name     String?
  outletId Int              @unique
  outlet   Outlet?          @relation(fields: [outletId], references: [id], onDelete: Cascade)
  items    InventoryItems[]
}

model Location {
  id    Int             @id @default(autoincrement())
  aisle String?
  rack  String?
  shelf String?
  item  InventoryItems?
}

model InventoryItems {
  id          Int       @id @default(autoincrement())
  inventoryId Int
  inventory   Inventory @relation(fields: [inventoryId], references: [id])
  itemId      Int
  item        Item      @relation(fields: [itemId], references: [id])
  price       Float
  quantity    Int       @default(0)
  locationId  Int?      @unique
  location    Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([inventoryId, itemId])
}

model Category {
  id           Int     @id @default(autoincrement())
  name         String  @unique
  description  String?
  groupType    String?
  stocks       String?
  sales        String?
  cost_of_sale String?
  items        Item[]
}

model Color {
  id      Int     @id @default(autoincrement())
  name    String  @unique
  hexCode String?
  items   Item[] // A color can be associated with many items
}

//! UPDATED PLEASE UPDATE THE TYPEDEFS
model Item {
  id             Int              @id @default(autoincrement())
  name           String           @unique
  itemCode       String?
  image          String?
  skuNumber      String?
  color          Color[]
  description    String?
  barcode        String
  brandId        Int?
  assembly       Boolean          @default(false)
  vatExempt      Boolean          @default(false)
  ServiceCharge  Boolean          @default(false)
  brandDetails   Brand?           @relation(fields: [brandId], references: [id])
  brand          String?
  categoryId     Int?
  category       Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  InventoryItems InventoryItems[]
  cartItems      CartItem[]

  purchaseUnit ItemUnit[]
}

model StockLocation {
  id      Int    @id @default(autoincrement())
  name    String
  address String
}

model Brand {
  id            Int     @id @default(autoincrement())
  name          String  @unique
  email         String?
  contactNumber String?
  webUrl        String?

  Item Item[]
}

model ItemUnit {
  id          Int     @id @default(autoincrement())
  unitName    String  @unique
  description String?

  Item Item[]
}

model CartItem {
  // A transaction can have many items, and an item can be in many transactions.
  // This model links them and outlet the quantity for each.
  transactionId Int
  itemId        Int
  quantity      Int

  transaction Transaction @relation(fields: [transactionId], references: [id])
  item        Item        @relation(fields: [itemId], references: [id])

  // A composite primary key ensures each item appears only once per transaction.
  @@id([transactionId, itemId])
}

enum PaymentMethod {
  CARD
  CASH
  E_WALLET
}

enum Status {
  PENDING
  PAID
  SYNCED
  FAILED
  CANCELED
}

model Transaction {
  id                Int              @id @default(autoincrement())
  outletId          Int
  outlet            Outlet           @relation(fields: [outletId], references: [id])
  cashierId         Int
  cashier           User             @relation(fields: [cashierId], references: [id])
  //  deviceId      Int
  //  device        Device        @relation(fields: [deviceId], references: [id])
  items             CartItem[]
  total             Float
  vatAmount         Float
  subtotal          Float
  cashReceived      Float?
  change            Float?
  paymentMethod     PaymentMethod
  customerDetailsId Int?
  customerDetails   CustomerDetails?
  status            Status
  createdAt         DateTime
  syncedAt          DateTime         @default(now())
  //retryCount    Int
}

enum PaymentType {
  gcash
  paymaya
  card
  qrph
}

model CustomerDetails {
  id              Int         @id @default(autoincrement())
  fullname        String?
  username        String?
  email           String?
  phoneNumber     String?
  paymentType     PaymentType
  paymentMethodId String? // From PayMongo: pm_...
  paymentIntentId String? // From PayMongo: pi_...
  client_key      String?
  status          String? // succeeded, failed, etc.
  transactionId   Int         @unique
  transaction     Transaction @relation(fields: [transactionId], references: [id])
}

// inventory
model Supplier {
  id            Int     @id @default(autoincrement())
  name          String
  address       String?
  zipCode       String?
  contactNumber String
  contactName   String
  faxNumber     String?
  tinNumber     String?

  // One-to-many relation
  modesOfPayment ModeOfPayment[]
}

model ModeOfPayment {
  id          Int         @id @default(autoincrement())
  name        String
  accountLink AccountLink?
  supplier    Supplier    @relation(fields: [supplierId], references: [id])
  supplierId  Int
}

