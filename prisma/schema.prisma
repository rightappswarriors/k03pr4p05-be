  change            Float?
  paymentMethod     PaymentMethod
  status            Status
  createdAt         DateTime
  syncedAt          DateTime         @default(now())
  customerDetailsId Int?
  customerType      CustomerType     @default(REGULAR)
  scPwdCustomerId   String?
  isVatExempt       Boolean          @default(false)
