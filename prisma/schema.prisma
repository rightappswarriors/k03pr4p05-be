generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id               Int               @id @default(autoincrement())
  name             String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime?         @updatedAt
  deletedAt        DateTime?
  bannerImg        String?
  profileImg       String?
  contactNumber    String?
  email            String?
  location         String?
  profilePhoto     String?
  facebookLink     String?
  instagramLink    String?
  twitterLink      String?
  bio              String?
  accountTitles    AccountTitle[]
  attendances      Attendance[]
  branches         Branch[]
  brands           Brand[]
  budgets          Budget[]
  centers          Center[]
  contacts         Contact[]
  departments      Department[]
  employees        Employee[]
  gisRows          GISRow[]
  inventoryItems   InventoryItem[]
  items            Item[]
  itemGroups       ItemGroup[]
  notifications    Notification[]
  orgCategories    OrgItemCategory[]
  outlets          Outlet[]
  positions        Position[]
  promoTypes       PromoType[]
  restockCycles    RestockCycle[]
  restockSchedules RestockSchedule[]
  salesOrders      SalesOrder[]
  scPwdCustomers   ScPwdCustomer[]
  shifts           Shift[]
  stockBatches     StockBatch[]
  subCenters       SubCenter[]
  subscription     Subscription?
  summaryRows      SummaryRow[]
  supplierOrders   SupplierOrder[]
  users            User[]
  vatTypes         VatType[]
}

model Subscription {
  id        Int              @id @default(autoincrement())
  orgId     Int              @unique
  plan      SubscriptionPlan @default(BASIC)
  expiresAt DateTime?
  features  Json?
  createdAt DateTime         @default(now())
  org       Organization     @relation(fields: [orgId], references: [id])
}

enum SubscriptionPlan {
  BASIC
  GOLD
}

model User {
  id                   Int                      @id @default(autoincrement())
  fullname             String
  username             String                   @unique
  email                String                   @unique
  role                 Role                     @default(CASHIER)
  password             String
  createdAt            DateTime                 @default(now())
  profilePhoto         String?
  managerId            Int?
  enabledPaymentMethod Boolean                  @default(false)
  contactNumber        String?
  orgId                Int?
  isVerified           Boolean                  @default(false)
  verificationCode     String?
  country              String?
  zipCode              String?
  city                 String?
  address              String?
  dateOfBirth          DateTime?
  isOwner              Boolean                  @default(false)
  positionId           String?
  departmentId         Int?
  attendances          Attendance[]
  auditLogs            AuditLog[]
  discountAudits       DiscountAudit[]          @relation("DiscountAuditUser")
  branchesOwned        Branch[]                 @relation("UserBranches")
  budgets              Budget[]
  employees            Employee[]
  gisRows              GISRow[]
  inventoryItems       InventoryItem[]
  outletOwned          Outlet[]                 @relation("UserOutlets")
  outletPromo          OutletPromo[]            @relation("UserOutletPromos")
  outletStaff          OutletStaff[]
  paymongoAPIKeys      PaymongoAPIKeys?
  promoType            PromoType[]              @relation("UserPromoTypes")
  salesOrders          SalesOrder[]
  summaryRows          SummaryRow[]
  Transaction          Transaction[]
  department           Department?              @relation(fields: [departmentId], references: [id])
  manager              User?                    @relation("ManagerToStaff", fields: [managerId], references: [id])
  staff                User[]                   @relation("ManagerToStaff")
  org                  Organization?            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  position             Position?                @relation(fields: [positionId], references: [id])
  permissionOverrides  UserPermissionOverride[]
  userShifts           UserShift[]
  updatedAt           DateTime?                 @updatedAt
  @@unique([orgId, username])
  @@unique([orgId, email])
}

model PaymongoAPIKeys {
  id         Int      @id @default(autoincrement())
  public_key String
  secret_key String
  ownerId    Int      @unique
  outlets    Outlet[] @relation("OutletApiKeys")
  owner      User     @relation(fields: [ownerId], references: [id])
}

model Branch {
  id               Int               @id @default(autoincrement())
  name             String
  address          String
  phone            String?
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  orgId            Int
  ownerId          Int
  locationId       Int?
  org              Organization      @relation(fields: [orgId], references: [id])
  owner            User              @relation("UserBranches", fields: [ownerId], references: [id], onDelete: Cascade)
  contacts         Contact[]
  outlets          Outlet[]
  location         PlaceLocation?
  restockCycles    RestockCycle[]
  restockSchedules RestockSchedule[]
  salesOrders      SalesOrder[]

  @@unique([orgId, name])
}

model Contact {
  id         Int          @id @default(autoincrement())
  orgId      Int
  branchId   Int?
  label      String
  name       String
  email      String
  phone      String?
  position   String?
  department String?
  notes      String?
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  branch     Branch?      @relation(fields: [branchId], references: [id])
  org        Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@index([orgId, branchId])
}

model PlaceLocation {
  id        Int    @id @default(autoincrement())
  address   String
  latitude  Float
  longitude Float
  branchId  Int    @unique
  branch    Branch @relation(fields: [branchId], references: [id])
}

model Outlet {
  id                    Int                     @id @default(autoincrement())
  name                  String
  address               String
  phone                 String?
  code                  String                  @unique
  nextTransactionNumber Int?                    @default(1)
  governmentTax         Float?
  serviceCharge         Float?
  outletType            OutletType
  isActive              Boolean                 @default(true)
  wifiSSID              String?
  createdAt             DateTime                @default(now())
  orgId                 Int
  branchId              Int?
  ownerId               Int
  apiKeyId              Int?
  hasKey                Boolean                 @default(false)
  status                OutletStatus            @default(open)
  latitude              Float?
  longitude             Float?
  bannerImage           String?
  bir                   String?
  isVatRegistered       Boolean                 @default(false)
  ptu                   String?
  tin                   String?
  vatTypeId             Int?
  vatZeroSale           Float?                  @default(0)
  inventory             Inventory?
  kompraCOrders         KompraCOrder[]
  notifications         Notification[]
  apiKey                PaymongoAPIKeys?        @relation("OutletApiKeys", fields: [apiKeyId], references: [id])
  branch                Branch?                 @relation(fields: [branchId], references: [id])
  org                   Organization            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner                 User                    @relation("UserOutlets", fields: [ownerId], references: [id], onDelete: Cascade)
  vatType               VatType?                @relation(fields: [vatTypeId], references: [id])
  deliveryConfig        OutletDeliveryConfig?
  itemSearchIndex       OutletItemSearchIndex[]
  outletPromos          OutletPromo[]
  staff                 OutletStaff[]
  restockCycles         RestockCycle[]
  restockSchedules      RestockSchedule[]
  Transaction           Transaction[]
  salesOrders           SalesOrder[]

  @@unique([orgId, code])
}

model PromoType {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  description  String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  orgId        Int
  userId       Int?
  outletPromos OutletPromo[]
  org          Organization  @relation(fields: [orgId], references: [id])
  user         User?         @relation("UserPromoTypes", fields: [userId], references: [id])

  @@unique([orgId, name])
}

model OutletPromo {
  id           Int           @id @default(autoincrement())
  outletId     Int
  promoTypeId  Int
  discount     Float
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  userId       Int
  vatable      Boolean       @default(false)
  outlet       Outlet        @relation(fields: [outletId], references: [id], onDelete: Cascade)
  promoType    PromoType     @relation(fields: [promoTypeId], references: [id], onDelete: Cascade)
  user         User          @relation("UserOutletPromos", fields: [userId], references: [id])
  transactions Transaction[]

  @@unique([outletId, promoTypeId])
}

model OutletStaff {
  id        Int       @id @default(autoincrement())
  outletId  Int
  userId    Int
  role      Role
  isPresent Boolean   @default(false)
  logInTime DateTime?
  outlet    Outlet    @relation(fields: [outletId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([outletId, userId])
}

model UnauthorizedAttempt {
  id                Int      @id @default(autoincrement())
  outletId          Int
  attemptedDeviceId String
  timestamp         DateTime @default(now())
}

model Inventory {
  id       Int              @id @default(autoincrement())
  name     String?
  outletId Int              @unique
  outlet   Outlet           @relation(fields: [outletId], references: [id], onDelete: Cascade)
  items    InventoryItems[]
}

model Location {
  id    Int             @id @default(autoincrement())
  aisle String?
  rack  String?
  shelf String?
  item  InventoryItems?
}

model StockMovement {
  id              Int               @id @default(autoincrement())
  itemId          Int
  inventoryItemId Int?
  outletId        Int?
  type            StockMovementType
  quantity        Float
  quantityBefore  Float
  quantityAfter   Float
  referenceId     String?
  referenceType   String?
  reason          String?
  createdAt       DateTime          @default(now())
  createdBy       Int
  item            Item              @relation(fields: [itemId], references: [id])
}

model InventoryItems {
  id          Int                    @id @default(autoincrement())
  inventoryId Int
  itemId      Int
  price       Float
  quantity    Int                    @default(0)
  locationId  Int?                   @unique
  categoryId  Int?
  baseUnit    String                 @default("piece")
  units       InventoryItemUnit[]
  category    ItemCategory?          @relation(fields: [categoryId], references: [id])
  inventory   Inventory              @relation(fields: [inventoryId], references: [id])
  item        Item                   @relation(fields: [itemId], references: [id])
  location    Location?              @relation(fields: [locationId], references: [id], onDelete: Cascade)
  orderItems  KompraCOrderItem[]
  searchIndex OutletItemSearchIndex?

  @@unique([inventoryId, itemId])
}

model ItemCategory {
  id             Int               @id @default(autoincrement())
  name           String            @unique
  description    String?
  groupType      String?
  sales          String?
  stocks         String?
  createdAt      DateTime          @default(now())
  icon           String?
  inventoryItems InventoryItems[]
  items          Item[]            @relation("GlobalItemCategory")
  orgCategories  OrgItemCategory[]
}

model OrgItemCategory {
  id             Int               @id @default(autoincrement())
  orgId          Int
  categoryId     Int?
  name           String
  description    String?
  icon           String?
  cost_of_sale   String?
  groupType      String?
  sales          String?
  stocks         String?
  groupId        Int?
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  items          Item[]
  itemCategories ItemCategoryMap[]
  globalCategory ItemCategory?     @relation(fields: [categoryId], references: [id])
  group          ItemGroup?        @relation(fields: [groupId], references: [id])
  org            Organization      @relation(fields: [orgId], references: [id])

  @@unique([orgId, name])
}

model ItemGroup {
  id          Int               @id @default(autoincrement())
  name        String
  description String?
  icon        String?
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  orgId       Int
  org         Organization      @relation(fields: [orgId], references: [id])
  categories  OrgItemCategory[]

  @@unique([orgId, name])
}

model ItemCategoryMap {
  itemId     Int
  categoryId Int
  category   OrgItemCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  item       Item            @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([itemId, categoryId])
}

model VatType {
  id          Int          @id @default(autoincrement())
  orgId       Int
  name        String
  rate        Float
  items       Item[]
  outlets     Outlet[]
  summaryRows SummaryRow[]
  org         Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, name])
}

model Item {
  id                         Int                     @id @default(autoincrement())
  name                       String                  @unique
  image                      String?
  description                String?
  barcode                    String
  brand                      String?
  orgId                      Int
  categoryId                 Int?
  brandId                    Int?
  ServiceCharge              Boolean                 @default(false)
  assembly                   Boolean                 @default(false)
  itemCode                   String?
  skuNumber                  String?
  vatExempt                  Boolean?
  isVatExempt                Boolean                 @default(false)
  isBNPC                     Boolean                 @default(false)
  hasSeniorDiscountVATExempt Boolean                 @default(false)
  vatRate                    Float                   @default(0.12)
  stock                      Float                   @default(0)
  sellingPrice               Float                   @default(0)
  minQuantity                Float                   @default(0)
  opExPct                    Float                   @default(0.1)
  priceB                     Float?
  priceC                     Float?
  totalCost                  Float                   @default(0)
  expiryEndDate              DateTime?
  expiryStartDate            DateTime?
  exactExpiryDate            DateTime?
  orgCategoryId              Int?
  vatTypeId                  Int?
  stockDescription           String?
  stockLabel                 String?
  cartItems                  CartItem[]
  costLines                  CostLines[]
  InventoryItems             InventoryItems[]
  brandDetails               Brand?                  @relation(fields: [brandId], references: [id])
  category                   ItemCategory?           @relation("GlobalItemCategory", fields: [categoryId], references: [id])
  orgCategory                OrgItemCategory?        @relation(fields: [orgCategoryId], references: [id])
  org                        Organization            @relation(fields: [orgId], references: [id])
  vatType                    VatType?                @relation(fields: [vatTypeId], references: [id])
  categories                 ItemCategoryMap[]
  orderItems                 KompraCOrderItem[]
  media                      Media[]
  notifications              Notification[]
  searchIndex                OutletItemSearchIndex[]
  restockCycleItems          RestockCycleItem[]
  restockScheduleItems       RestockScheduleItem[]
  stockBatches               StockBatch[]
  stockMovements             StockMovement[]
  summaryRows                SummaryRow[]
  supplierOrderItems         SupplierOrderItem[]
  discountAudits             DiscountAudit[]         @relation("DiscountAuditItem")
  color                      Color[]                 @relation("ColorToItem")
  purchaseUnit               ItemUnit[]              @relation("ItemToItemUnit")
  salesOrderItems            SalesOrderItem[]

  @@unique([orgId, name])
}

enum OrderMode {
  WALK_IN
  PICK_UP
  DELIVERY
}

enum SalesOrderStatus {
  PENDING
  PROCESSING
  READY_FOR_PICKUP
  OUT_FOR_DELIVERY
  COMPLETED
  ORDERED
  SHIPPED
  RECEIVED
  CANCELLED
}

model SalesOrder {
  id                String           @id @default(cuid())
  orderNumber       String           @unique
  customer          String
  orderMode         OrderMode        @default(WALK_IN)
  status            SalesOrderStatus @default(PENDING)
  date              DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  orgId             Int
  userId            Int?
  outletId          Int?
  branchId          Int?
  customerName      String?
  customerContact   String?
  customerType      CustomerType     @default(REGULAR)
  discountType      DiscountType     @default(NONE)
  vatExemptSale     Float            @default(0)
  totalPax          Int?
  scPwdPax          Int?
  scPwdCustomerId   String?
  deliveryAddress   String?
  deliveryNotes     String?
  // Pricing
  subtotal          Float            @default(0)
  discountAmount    Float            @default(0)
  vatAmount         Float            @default(0)
  total             Float            @default(0)
  vatRate           Float            @default(0)
  discountRate      Float            @default(0)
  extraChargesTotal Float            @default(0)
  grandTotal        Float            @default(0)
  outletPromoId     Int?

  // Delivery details (filled when moving Processing → Shipped)
  delivery SalesOrderDelivery?

  // Relations
  items         SalesOrderItem[]
  extraCharges  ExtraCharge[]
  org           Organization     @relation(fields: [orgId], references: [id])
  user          User?            @relation(fields: [userId], references: [id])
  outlet        Outlet?          @relation(fields: [outletId], references: [id])
  branch        Branch?          @relation(fields: [branchId], references: [id])
  scPwdCustomer ScPwdCustomer?   @relation(fields: [scPwdCustomerId], references: [id])

  @@index([orgId])
  @@index([orgId, status])
  @@index([orgId, orderMode])
  @@index([scPwdCustomerId])
  @@index([outletId])
}

model ExtraCharge {
  id           String     @id @default(cuid())
  label        String
  amount       Float
  salesOrderId String
  createdAt    DateTime   @default(now())
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)

  @@index([salesOrderId])
}

model SalesOrderItem {
  id               Int          @id @default(autoincrement())
  salesOrderId     String
  itemId           Int?
  quantity         Float
  unitPrice        Float
  totalPrice       Float
  discountQuantity Float?       @default(0)
  discountRate     Float?       @default(0)
  discountAmount   Float?       @default(0)
  discountType     DiscountType @default(NONE)
  unitId           Int?
  unitName         String?

  // ── Custom / manual item fields ──────────────────────────────────────────
  isCustomItem   Boolean @default(false) // true = manually entered, not from inventory
  customItemName String? // display name for custom items
  vatExempt      Boolean @default(false) // VAT override; used when isCustomItem = true

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  item       Item?      @relation(fields: [itemId], references: [id]) // ← nullable relation

  @@index([salesOrderId])
}

model SalesOrderDelivery {
  id             Int        @id @default(autoincrement())
  salesOrderId   String     @unique
  courierName    String?
  trackingNumber String?
  address        String
  contactPerson  String?
  contactNumber  String?
  notes          String?
  estimatedDate  DateTime?
  shippedAt      DateTime?
  receivedAt     DateTime?
  salesOrder     SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
}

model ItemUnit {
  id          Int     @id @default(autoincrement())
  unitName    String  @unique
  description String?
  Item        Item[]  @relation("ItemToItemUnit")
}

model InventoryItemUnit {
  id               Int                @id @default(autoincrement())
  inventoryItemId  Int
  unitName         String
  unitLabel        String
  price            Float
  quantity         Float              @default(0)
  conversionFactor Float              @default(1)
  baseUnit         String             @default("piece")
  barcode          String?
  isDefault        Boolean            @default(false)
  isActive         Boolean            @default(true)
  minOrderQty      Float?
  maxOrderQty      Float?
  reorderPoint     Float?
  allowDecimal     Boolean            @default(false)
  cartItems        CartItem[]
  inventoryItem    InventoryItems     @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  orderItems       KompraCOrderItem[]

  @@unique([inventoryItemId, unitName])
  @@index([inventoryItemId])
}

model CustomerDetails {
  id              Int         @id @default(autoincrement())
  fullname        String?
  username        String?
  email           String?
  phoneNumber     String?
  paymentType     PaymentType
  paymentMethodId String?
  paymentIntentId String?
  client_key      String?
  status          String?
  transactionId   Int         @unique
  transaction     Transaction @relation(fields: [transactionId], references: [id])
}

model KompraCOrder {
  id                     Int                       @id @default(autoincrement())
  transactionNumber      String                    @unique
  customerId             Int
  outletId               Int
  deliveryAddressId      Int
  subtotal               Float
  total                  Float
  status                 OrderStatus               @default(pending)
  scheduledDeliveryAt    DateTime?
  estimatedDeliveryAt    DateTime?
  deliveredAt            DateTime?
  paymentMethod          KompraCPaymentMethod
  paymentStatus          String                    @default("unpaid")
  paymentReference       String?
  riderName              String?
  riderPhone             String?
  customerNote           String?
  outletNote             String?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  courierId              Int?
  tracking               KompraCDeliveryTracking[]
  courier                Courier?                  @relation(fields: [courierId], references: [id])
  customer               KompraCustomer            @relation(fields: [customerId], references: [id])
  deliveryAddress        DeliveryAddress           @relation(fields: [deliveryAddressId], references: [id])
  outlet                 Outlet                    @relation(fields: [outletId], references: [id])
  fees                   KompraCOrderFee[]
  items                  KompraCOrderItem[]
  OrderCourierPreference OrderCourierPreference[]
}

enum OrderStatus {
  pending
  confirmed
  preparing
  in_delivery
  received
  cancelled
  returned
}

model Courier {
  id                     Int                      @id @default(autoincrement())
  name                   String
  phone                  String
  createdAt              DateTime                 @default(now())
  orders                 KompraCOrder[]
  OrderCourierPreference OrderCourierPreference[]
  api_order              api_order[]
}

model KompraCustomer {
  id           Int                   @id @default(autoincrement())
  fullname     String
  email        String                @unique
  passwordHash String
  profilePhoto String?
  isVerified   Boolean               @default(false)
  isActive     Boolean               @default(true)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  phone        String?               @unique
  deviceTokens CustomerDeviceToken[]
  addresses    DeliveryAddress[]
  orders       KompraCOrder[]
}

model DeliveryAddress {
  id         Int            @id @default(autoincrement())
  customerId Int
  label      String
  address    String
  latitude   Float
  longitude  Float
  isDefault  Boolean        @default(false)
  createdAt  DateTime       @default(now())
  customer   KompraCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orders     KompraCOrder[]
}

model KompraCOrderItem {
  id              Int                @id @default(autoincrement())
  orderId         Int
  inventoryItemId Int
  itemId          Int
  quantity        Int
  priceSnapshot   Float
  subtotal        Float
  unitId          Int?
  inventoryItem   InventoryItems     @relation(fields: [inventoryItemId], references: [id])
  item            Item               @relation(fields: [itemId], references: [id])
  order           KompraCOrder       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  unit            InventoryItemUnit? @relation(fields: [unitId], references: [id])

  @@unique([orderId, inventoryItemId])
}

model KompraCOrderFee {
  id      Int          @id @default(autoincrement())
  orderId Int
  type    FeeType
  label   String
  amount  Float
  order   KompraCOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model KompraCDeliveryTracking {
  id         Int                 @id @default(autoincrement())
  orderId    Int
  event      DeliveryStatusEvent
  statusAt   DateTime            @default(now())
  currentLat Float?
  currentLng Float?
  note       String?
  actorType  String
  actorId    Int?
  order      KompraCOrder        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, statusAt])
}

model OutletDeliveryConfig {
  id               Int     @id @default(autoincrement())
  outletId         Int     @unique
  isDeliveryActive Boolean @default(true)
  deliveryRadiusKm Float   @default(5.0)
  baseDeliveryFee  Float   @default(50.0)
  feePerKm         Float   @default(10.0)
  minOrderAmount   Float?
  maxOrderAmount   Float?
  avgPrepMins      Int     @default(15)
  outlet           Outlet  @relation(fields: [outletId], references: [id], onDelete: Cascade)
}

model OutletItemSearchIndex {
  id              Int            @id @default(autoincrement())
  outletId        Int
  itemId          Int
  inventoryItemId Int            @unique
  quantity        Int
  price           Float
  outletLatitude  Float
  outletLongitude Float
  inventoryItem   InventoryItems @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  item            Item           @relation(fields: [itemId], references: [id], onDelete: Cascade)
  outlet          Outlet         @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@unique([outletId, itemId])
  @@index([itemId, quantity])
  @@index([outletId])
}

model Color {
  id      Int     @id @default(autoincrement())
  name    String  @unique
  hexCode String?
  items   Item[]  @relation("ColorToItem")
}

model CostLines {
  id     Int    @id @default(autoincrement())
  itemId Int
  label  String
  amount Float
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}

model SupplierOrder {
  id              Int                 @id @default(autoincrement())
  orgId           Int
  scheduleId      Int?
  supplierEmail   String
  supplierToken   String              @unique
  tokenExpiresAt  DateTime
  status          SupplierOrderStatus @default(pending)
  supplierMessage String?
  userMessage     String?
  expectedArrival DateTime
  createdAt       DateTime            @default(now())
