generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // dont change this
}

// ─── Multi-Tenancy Models ─────────────────────────────────────────────────────

model Organization {
  id             Int             @id @default(autoincrement())
  name           String
  createdAt      DateTime        @default(now())
  subscription   Subscription?
  users          User[]
  branches       Branch[]
  outlets        Outlet[]
  items          Item[]
  itemCategories ItemCategory[]
  vatTypes       VatType[]
  departments    Department[]
  positions      Position[]
  centers        Center[]
  subCenters     SubCenter[]
  accountTitles  AccountTitle[]
  gisRows        GISRow[]
  summaryRows    SummaryRow[]
  salesOrders    SalesOrder[]
  inventoryItems InventoryItem[]
  employees      Employee[]
  promoTypes     PromoType[] // Added for PromoType relation
  itemGroups     ItemGroup[] // Added for ItemGroup relation
  brands         Brand[] // Added for Brand relation
  shifts         Shift[]
  attendances    Attendance[]
}

model Subscription {
  id        Int              @id @default(autoincrement())
  orgId     Int              @unique
  plan      SubscriptionPlan @default(BASIC)
  expiresAt DateTime?
  features  Json? // Extensible for feature gating
  createdAt DateTime         @default(now())
  org       Organization     @relation(fields: [orgId], references: [id])
}

enum SubscriptionPlan {
  BASIC
  GOLD
}

// ─── User Model (Updated for Multi-Tenancy) ───────────────────────────────────

model User {
  id                   Int              @id @default(autoincrement())
  fullname             String
  username             String           @unique // Global unique for simplicity; adjust if needed
  email                String           @unique // Global unique
  role                 Role             @default(CASHIER)
  password             String
  isVerified           Boolean          @default(false)
  verificationCode     String?
  createdAt            DateTime         @default(now())
  profilePhoto         String?
  managerId            Int?
  enabledPaymentMethod Boolean          @default(false)
  contactNumber        String?
  orgId                Int? // Added for multi-tenancy - optional during onboarding until org created
  org                  Organization?    @relation(fields: [orgId], references: [id])
  branchesOwned        Branch[]         @relation("UserBranches")
  outletOwned          Outlet[]         @relation("UserOutlets")
  outletPromo          OutletPromo[]    @relation("UserOutletPromos")
  outletStaff          OutletStaff[]
  paymongoAPIKeys      PaymongoAPIKeys?
  promoType            PromoType[]      @relation("UserPromoTypes")
  Transaction          Transaction[]
  manager              User?            @relation("ManagerToStaff", fields: [managerId], references: [id])
  staff                User[]           @relation("ManagerToStaff")
  employees            Employee[] // Added relation to HR employees
  gisRows              GISRow[] // Added for ERP data
  summaryRows          SummaryRow[]
  salesOrders          SalesOrder[]
  inventoryItems       InventoryItem[]
  userShifts           UserShift[]
  attendances          Attendance[]

  @@unique([orgId, username]) // Per-org unique for scalability
  @@unique([orgId, email]) // Per-org unique
}

model PaymongoAPIKeys {
  id         Int      @id @default(autoincrement())
  public_key String
  secret_key String
  ownerId    Int      @unique
  outlets    Outlet[] @relation("OutletApiKeys")
  owner      User     @relation(fields: [ownerId], references: [id])
}

model Branch {
  id         Int            @id @default(autoincrement())
  name       String
  address    String
  phone      String?
  isActive   Boolean        @default(true)
  createdAt  DateTime       @default(now())
  orgId      Int // Added for multi-tenancy
  org        Organization   @relation(fields: [orgId], references: [id])
  ownerId    Int
  locationId Int?
  owner      User           @relation("UserBranches", fields: [ownerId], references: [id])
  outlets    Outlet[]
  location   PlaceLocation?

  @@unique([orgId, name]) // Per-org unique
}

model PlaceLocation {
  id        Int    @id @default(autoincrement())
  address   String
  latitude  Float
  longitude Float
  branchId  Int    @unique
  branch    Branch @relation(fields: [branchId], references: [id])
}

model Outlet {
  id                    Int                     @id @default(autoincrement())
  name                  String
  address               String
  phone                 String?
  code                  String                  @unique // Keep global for now; adjust if needed
  nextTransactionNumber Int?                    @default(1)
  governmentTax         Float?
  serviceCharge         Float?
  outletType            OutletType
  isActive              Boolean                 @default(true)
  wifiSSID              String?
  createdAt             DateTime                @default(now())
  orgId                 Int // Added for multi-tenancy
  org                   Organization            @relation(fields: [orgId], references: [id])
  branchId              Int?
  ownerId               Int
  apiKeyId              Int?
  hasKey                Boolean                 @default(false)
  status                OutletStatus            @default(open)
  latitude              Float?
  longitude             Float?
  imageBanner           String?
  
  bannerImage           String?
  kompraCOrders         KompraCOrder[]
  inventory             Inventory?
  apiKey                PaymongoAPIKeys?        @relation("OutletApiKeys", fields: [apiKeyId], references: [id])
  branch                Branch?                 @relation(fields: [branchId], references: [id])
  owner                 User                    @relation("UserOutlets", fields: [ownerId], references: [id])
  deliveryConfig        OutletDeliveryConfig?
  itemSearchIndex       OutletItemSearchIndex[]
  outletPromos          OutletPromo[]
  staff                 OutletStaff[]
  Transaction           Transaction[]

  @@unique([orgId, code]) // Per-org unique
}

model PromoType {
  id           Int           @id @default(autoincrement())
  name         String        @unique // Keep global; adjust if needed
  description  String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  orgId        Int // Added for multi-tenancy
  org          Organization  @relation(fields: [orgId], references: [id])
  userId       Int?
  outletPromos OutletPromo[]
  user         User?         @relation("UserPromoTypes", fields: [userId], references: [id])

  @@unique([orgId, name]) // Per-org unique
}

model OutletPromo {
  id          Int       @id @default(autoincrement())
  outletId    Int
  promoTypeId Int
  discount    Float
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  userId      Int
  outlet      Outlet    @relation(fields: [outletId], references: [id], onDelete: Cascade)
  promoType   PromoType @relation(fields: [promoTypeId], references: [id], onDelete: Cascade)
  user        User      @relation("UserOutletPromos", fields: [userId], references: [id])

  @@unique([outletId, promoTypeId])
}

model OutletStaff {
  id        Int     @id @default(autoincrement())
  outletId  Int
  userId    Int
  role      Role
  isPresent Boolean @default(false)
  logInTime DateTime?
  outlet    Outlet  @relation(fields: [outletId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@unique([outletId, userId])
}

model UnauthorizedAttempt {
  id                Int      @id @default(autoincrement())
  outletId          Int
  attemptedDeviceId String
  timestamp         DateTime @default(now())
}

model Inventory {
  id       Int              @id @default(autoincrement())
  name     String?
  outletId Int              @unique
  outlet   Outlet           @relation(fields: [outletId], references: [id], onDelete: Cascade)
  items    InventoryItems[]
}

model Location {
  id    Int             @id @default(autoincrement())
  aisle String?
  rack  String?
  shelf String?
  item  InventoryItems?
}

model InventoryItems {
  id          Int                    @id @default(autoincrement())
  inventoryId Int
  itemId      Int
  price       Float
  quantity    Int                    @default(0)
  locationId  Int?                   @unique
  orderItems  KompraCOrderItem[]
  units       InventoryItemUnit[]
  inventory   Inventory              @relation(fields: [inventoryId], references: [id])
  item        Item                   @relation(fields: [itemId], references: [id])
  location    Location?              @relation(fields: [locationId], references: [id], onDelete: Cascade)
  searchIndex OutletItemSearchIndex?

  @@unique([inventoryId, itemId])
}

model ItemGroup {
  id          Int            @id @default(autoincrement())
  name        String         @unique // Keep global
  description String?
  icon        String?
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  orgId       Int // Added for multi-tenancy
  org         Organization   @relation(fields: [orgId], references: [id])
  categories  ItemCategory[]

  @@unique([orgId, name]) // Per-org unique
}

model ItemCategory {
  id             Int               @id @default(autoincrement())
  name           String            @unique // Keep global; adjust if needed
  cost_of_sale   String?
  description    String?
  groupType      String?
  sales          String?
  stocks         String?
  orgId          Int // Added for multi-tenancy
  org            Organization      @relation(fields: [orgId], references: [id])
  groupId        Int?
  group          ItemGroup?        @relation(fields: [groupId], references: [id])
  items          Item[]
  itemCategories ItemCategoryMap[]

  @@unique([orgId, name]) // Per-org unique
}

model ItemCategoryMap {
  itemId     Int
  categoryId Int
  category   ItemCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  item       Item         @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([itemId, categoryId])
}

model Color {
  id      Int     @id @default(autoincrement())
  name    String  @unique
  hexCode String?
  items   Item[]  @relation("ColorToItem")
}

model Item {
  id             Int                     @id @default(autoincrement())
  name           String                  @unique // Keep global; adjust if needed
  image          String?
  description    String?
  barcode        String
  brand          String?
  orgId          Int // Added for multi-tenancy
  org            Organization            @relation(fields: [orgId], references: [id])
  categoryId     Int?
  brandId        Int?
  ServiceCharge  Boolean                 @default(false)
  assembly       Boolean                 @default(false)
  itemCode       String?
  skuNumber      String?
  vatExempt      Boolean                 @default(false)
  cartItems      CartItem[]
  orderItems     KompraCOrderItem[]
  InventoryItems InventoryItems[]
  brandDetails   Brand?                  @relation(fields: [brandId], references: [id])
  category       ItemCategory?           @relation(fields: [categoryId], references: [id])
  categories     ItemCategoryMap[]
  media          Media[]
  searchIndex    OutletItemSearchIndex[]
  color          Color[]                 @relation("ColorToItem")
  purchaseUnit   ItemUnit[]              @relation("ItemToItemUnit")

  @@unique([orgId, name]) // Per-org unique
}

model Media {
  id        Int        @id @default(autoincrement())
  url       String
  type      MediaType?
  itemId    Int?
  sortOrder Int        @default(0)
  item      Item?      @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, sortOrder])
}

model StockLocation {
  id      Int    @id @default(autoincrement())
  name    String
  address String
}

model Brand {
  id            Int          @id @default(autoincrement())
  email         String?
  webUrl        String?
  contactNumber String?
  name          String       @unique // Keep global
  orgId         Int // Added for multi-tenancy
  org           Organization @relation(fields: [orgId], references: [id])
  Item          Item[]

  @@unique([orgId, name]) // Per-org unique
}

model ItemUnit {
  id          Int     @id @default(autoincrement())
  unitName    String  @unique
  description String?
  Item        Item[]  @relation("ItemToItemUnit")
}

model CartItem {
  transactionId Int
  itemId        Int
  quantity      Int
  item          Item        @relation(fields: [itemId], references: [id])
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  @@id([transactionId, itemId])
}

model Transaction {
  id                Int              @id @default(autoincrement())
  outletId          Int
  cashierId         Int
  total             Float
  vatAmount         Float
  subtotal          Float
  cashReceived      Float?
  change            Float?
  paymentMethod     PaymentMethod
  status            Status
  createdAt         DateTime
  syncedAt          DateTime         @default(now())
  customerDetailsId Int?
  items             CartItem[]
  customerDetails   CustomerDetails?
  cashier           User             @relation(fields: [cashierId], references: [id])
  outlet            Outlet           @relation(fields: [outletId], references: [id])
}

model CustomerDetails {
  id              Int         @id @default(autoincrement())
  fullname        String?
  username        String?
  email           String?
  phoneNumber     String?
  paymentType     PaymentType
  paymentMethodId String?
  paymentIntentId String?
  client_key      String?
  status          String?
  transactionId   Int         @unique
  transaction     Transaction @relation(fields: [transactionId], references: [id])
}

model KompraCustomer {
  id           Int                   @id @default(autoincrement())
  fullname     String
  email        String                @unique
  passwordHash String
  profilePhoto String?
  isVerified   Boolean               @default(false)
  isActive     Boolean               @default(true)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  phone        String?               @unique
  deviceTokens CustomerDeviceToken[]
  addresses    DeliveryAddress[]
  orders       KompraCOrder[]
}

model CustomerDeviceToken {
  id         Int            @id @default(autoincrement())
  customerId Int
  token      String         @unique
  platform   String
  createdAt  DateTime       @default(now())
  customer   KompraCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model DeliveryAddress {
  id         Int            @id @default(autoincrement())
  customerId Int
  label      String
  address    String
  latitude   Float
  longitude  Float
  isDefault  Boolean        @default(false)
  createdAt  DateTime       @default(now())
  customer   KompraCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orders     KompraCOrder[]
}

model KompraCOrder {
  id                  Int                       @id @default(autoincrement())
  transactionNumber   String                    @unique
  customerId          Int
  outletId            Int
  deliveryAddressId   Int
  subtotal            Float
  total               Float
  status              OrderStatus               @default(pending)
  scheduledDeliveryAt DateTime?
  estimatedDeliveryAt DateTime?
  deliveredAt         DateTime?
  paymentMethod       KompraCPaymentMethod
  paymentStatus       String                    @default("unpaid")
  paymentReference    String?
  riderName           String?
  riderPhone          String?
  customerNote        String?
  outletNote          String?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  tracking            KompraCDeliveryTracking[]
  customer            KompraCustomer            @relation(fields: [customerId], references: [id])
  deliveryAddress     DeliveryAddress           @relation(fields: [deliveryAddressId], references: [id])
  outlet              Outlet                    @relation(fields: [outletId], references: [id])
  fees                KompraCOrderFee[]
  items               KompraCOrderItem[]
}

model KompraCOrderItem {
  id              Int                @id @default(autoincrement())
  orderId         Int
  inventoryItemId Int
  itemId          Int
  quantity        Int
  priceSnapshot   Float
  subtotal        Float
  unitId          Int?
  inventoryItem   InventoryItems     @relation(fields: [inventoryItemId], references: [id])
  item            Item               @relation(fields: [itemId], references: [id])
  order           KompraCOrder       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  unit            InventoryItemUnit? @relation(fields: [unitId], references: [id])

  @@unique([orderId, inventoryItemId])
}

model KompraCOrderFee {
  id      Int          @id @default(autoincrement())
  orderId Int
  type    FeeType
  label   String
  amount  Float
  order   KompraCOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model KompraCDeliveryTracking {
  id         Int                 @id @default(autoincrement())
  orderId    Int
  event      DeliveryStatusEvent
  statusAt   DateTime            @default(now())
  currentLat Float?
  currentLng Float?
  note       String?
  actorType  String
  actorId    Int?
  order      KompraCOrder        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, statusAt])
}

model OutletDeliveryConfig {
  id               Int     @id @default(autoincrement())
  outletId         Int     @unique
  isDeliveryActive Boolean @default(true)
  deliveryRadiusKm Float   @default(5.0)
  baseDeliveryFee  Float   @default(50.0)
  feePerKm         Float   @default(10.0)
  minOrderAmount   Float?
  maxOrderAmount   Float?
  avgPrepMins      Int     @default(15)
  outlet           Outlet  @relation(fields: [outletId], references: [id], onDelete: Cascade)
}

model OutletItemSearchIndex {
  id              Int            @id @default(autoincrement())
  outletId        Int
  itemId          Int
  inventoryItemId Int            @unique
  quantity        Int
  price           Float
  outletLatitude  Float
  outletLongitude Float
  inventoryItem   InventoryItems @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  item            Item           @relation(fields: [itemId], references: [id], onDelete: Cascade)
  outlet          Outlet         @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@unique([outletId, itemId])
  @@index([itemId, quantity])
  @@index([outletId])
}

model InventoryItemUnit {
  id               Int                @id @default(autoincrement())
  inventoryItemId  Int
  unitName         String
  unitLabel        String
  price            Float
  quantity         Float              @default(0)
  conversionFactor Float              @default(1)
  baseUnit         String             @default("piece")
  barcode          String?
  isDefault        Boolean            @default(false)
  isActive         Boolean            @default(true)
  minOrderQty      Float?
  maxOrderQty      Float?
  reorderPoint     Float?
  orderItems       KompraCOrderItem[]
  inventoryItem    InventoryItems     @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@unique([inventoryItemId, unitName])
  @@index([inventoryItemId])
}

// ─── Master File Models (Per-Organization) ────────────────────────────────────

model VatType {
  id    Int          @id @default(autoincrement())
  label String
  orgId Int
  org   Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, label])
}

model Department {
  id    Int          @id @default(autoincrement())
  label String
  color String?
  orgId Int
  org   Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, label])
}

model Position {
  id    Int          @id @default(autoincrement())
  label String
  orgId Int
  org   Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, label])
}

model Center {
  id    Int          @id @default(autoincrement())
  label String
  orgId Int
  org   Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, label])
}

model SubCenter {
  id    Int          @id @default(autoincrement())
  label String
  orgId Int
  org   Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, label])
}

model AccountTitle {
  id    Int          @id @default(autoincrement())
  label String
  orgId Int
  org   Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, label])
}

// ─── HR Model ────────────────────────────────────────────────────────────────

model Employee {
  id         String         @id
  name       String
  role       String
  department String
  status     EmployeeStatus
  salary     Float
  hireDate   DateTime
  email      String         @unique // Global unique; adjust if needed
  orgId      Int
  userId     Int? // Optional link to User
  org        Organization   @relation(fields: [orgId], references: [id])
  user       User?          @relation(fields: [userId], references: [id])

  @@unique([orgId, email]) // Per-org unique
  @@index([orgId])
  @@index([department])
}

enum EmployeeStatus {
  Active
  On_Leave
  Contract
}

// ─── HR Time Tracking Models ────────────────────────────────────────────────

model Shift {
  id            Int          @id @default(autoincrement())
  name          String
  startTime     DateTime
  endTime       DateTime
  breakDuration Int          @default(0) // in minutes
  orgId         Int
  org           Organization @relation(fields: [orgId], references: [id])
  userShifts    UserShift[]
  attendances   Attendance[]

  @@index([orgId])
}

model UserShift {
  id         Int      @id @default(autoincrement())
  userId     Int
  shiftId    Int
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  shift      Shift    @relation(fields: [shiftId], references: [id])

  @@unique([userId, shiftId])
  @@index([userId])
  @@index([shiftId])
}

model Attendance {
  id              Int              @id @default(autoincrement())
  userId          Int
  shiftId         Int
  shiftDate       DateTime         @default(now())
  timeIn          DateTime?
  timeOut         DateTime?
  breakStart      DateTime?
  breakEnd        DateTime?
  photoIn         String?
  photoOut        String?
  photoBreakStart String?
  photoBreakEnd   String?
  status          AttendanceStatus @default(PRESENT)
  orgId           Int
  user            User             @relation(fields: [userId], references: [id])
  shift           Shift            @relation(fields: [shiftId], references: [id])
  org             Organization     @relation(fields: [orgId], references: [id])

  @@index([userId, shiftDate])
  @@index([shiftId, shiftDate])
  @@index([orgId])
}

enum AttendanceStatus {
  PRESENT
  ON_BREAK
  OFF_DUTY
}

// ─── ERP Data Models ──────────────────────────────────────────────────────────

model GISRow {
  id          String       @id
  main        String
  group       String
  code        String
  description String
  debit       Float
  credit      Float
  total       Float
  orgId       Int
  userId      Int?
  org         Organization @relation(fields: [orgId], references: [id])
  user        User?        @relation(fields: [userId], references: [id])

  @@index([orgId])
}

model SummaryRow {
  id               String       @id
  itemCode         String
  description      String
  opExPct          Float
  computedCost     Float
  costContribution Float
  sellingPrice     Float
  status           String?
  orgId            Int
  userId           Int?
  org              Organization @relation(fields: [orgId], references: [id])
  user             User?        @relation(fields: [userId], references: [id])

  @@index([orgId])
}

model SalesOrder {
  id       String       @id
  customer String
  product  String
  qty      Int
  total    Float
  status   String
  date     DateTime
  outlet   String
  orgId    Int
  userId   Int?
  org      Organization @relation(fields: [orgId], references: [id])
  user     User?        @relation(fields: [userId], references: [id])

  @@index([orgId])
}

model InventoryItem {
  id       String       @id
  name     String
  sku      String
  stock    Int
  minStock Int
  category String
  price    Float
  lowStock Boolean
  orgId    Int
  userId   Int?
  org      Organization @relation(fields: [orgId], references: [id])
  user     User?        @relation(fields: [userId], references: [id])

  @@index([orgId])
}

  enum Role {
    ADMIN
    MANAGER
    STAFF
    CASHIER
    OWNER
  }

enum OutletType {
  retail
  wholesale
  service
}

enum OutletStatus {
  open
  closed
  maintenance
}

enum PaymentMethod {
  CARD
  CASH
  E_WALLET
}

enum Status {
  PENDING
  PAID
  SYNCED
  FAILED
  CANCELED
}

enum PaymentType {
  gcash
  paymaya
  card
  qrph
}

enum MediaType {
  image
  video
}

enum OrderStatus {
  pending
  confirmed
  preparing
  in_delivery
  received
  cancelled
  returned
}

enum DeliveryStatusEvent {
  order_placed
  outlet_confirmed
  outlet_preparing
  rider_assigned
  rider_picked_up
  rider_en_route
  arrived_at_door
  delivered
  cancelled
  return_requested
  returned
}

enum FeeType {
  delivery
  packaging
  priority
  handling
  voucher_discount
}

enum KompraCPaymentMethod {
  cash_on_delivery
  gcash
  paymaya
  card
  qrph
}
